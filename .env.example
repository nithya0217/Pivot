# Copy this file to .env and fill in your secrets.
# Do not commit .env to git.

DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres

# Optional: if you prefer a single connection string instead of DB_* vars
# DATABASE_URL=postgresql://postgres:your_password_here@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
