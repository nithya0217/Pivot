# Production Environment for Render Deployment
# Set these environment variables in your Render Web Service dashboard

ENV=production
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=your-render-postgres-host.render.com
DB_PORT=5432
DB_NAME=postgres

# Alternative: if using an external database like Supabase
# ENV=production
# DATABASE_URL=postgresql://user:password@host:5432/dbname
